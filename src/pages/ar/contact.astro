---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/PageHero.astro';
import SectionHeader from '@/components/SectionHeader.astro';
import { common, company, inquiryPrompts, pages } from '@/data/content';
import { withBase } from '@/utils/paths';

const lang = 'ar';
const page = pages.contact;
const mailSubject = encodeURIComponent('استفسار منتجات الكسرة');
const mailBody = encodeURIComponent('مرحباً شركة الكسرة،\n\nأرغب في مناقشة فئات المواد الغذائية وخيارات التوريد.\n\nالشركة:\nالهاتف:\nالرسالة:');
const mailHref = `mailto:${company.email}?subject=${mailSubject}&body=${mailBody}`;
const productInquiryHref = withBase('/ar/products/#product-inquiry');
---

<BaseLayout lang={lang} pageKey="contact" title={page.meta[lang].title} description={page.meta[lang].description}>
  <PageHero
    lang={lang}
    eyebrow={page.hero.eyebrow[lang]}
    title={page.hero.title[lang]}
    lead={page.hero.lead[lang]}
    image={page.hero.image}
    imageAlt="مكونات مخزون غذائي مرتبة للاستفسار التجاري"
    primaryCta={{ label: common.ctas.quote[lang], href: productInquiryHref }}
    secondaryCta={{ label: common.ctas.email[lang], href: mailHref }}
  />

  <section class="content-band">
    <SectionHeader
      eyebrow="بيانات التواصل"
      title="تواصل مع الكسرة في رأس الخيمة"
      copy="للمتابعة السعرية الأوضح، اختر فئات المنتجات وأرسل استفسار واتساب المُجهّز. يمكنك أيضاً مراسلة الكسرة مباشرةً مع ذكر الفئة ونوع المشتري والكمية التقريبية وحجم العبوة والوجهة وأي مستندات مطلوبة."
    />
    <div class="prompt-strip">
      {inquiryPrompts.map((prompt) => <span>{prompt[lang]}</span>)}
    </div>
    <div class="contact-grid">
      <article class="contact-tile">
        <span>البريد الإلكتروني</span>
        <a href={mailHref}>{company.email}</a>
      </article>
      <article class="contact-tile">
        <span>الموقع</span>
        <strong>{company.location[lang]}</strong>
      </article>
      <article class="contact-tile">
        <span>واتساب</span>
        <a href={`https://wa.me/${company.whatsapp.replace(/\D/g, '')}`}>{company.whatsapp}</a>
      </article>
      <article class="contact-tile">
        <span>الهاتف</span>
        <a href={`tel:${company.phone.replace(/\s/g, '')}`}>{company.phone}</a>
      </article>
    </div>
    <div class="contact-actions">
      <a class="button button-primary" href={productInquiryHref}>{common.ctas.quote[lang]}</a>
      <a class="button button-secondary" href={mailHref}>{common.ctas.email[lang]}</a>
    </div>
  </section>
</BaseLayout>
