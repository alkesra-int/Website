---
import BaseLayout from '@/layouts/BaseLayout.astro';
import BuyerSegments from '@/components/BuyerSegments.astro';
import HomeHero from '@/components/HomeHero.astro';
import SupplyStory from '@/components/SupplyStory.astro';
import { company, pages } from '@/data/content';
import { withBase } from '@/utils/paths';

const lang = 'ar';
const page = pages.home;
---

<BaseLayout lang={lang} pageKey="home" title={page.meta[lang].title} description={page.meta[lang].description}>
  <HomeHero lang={lang} />

  <section class="trust-strip" aria-label="مميزات الكسرة">
    {page.stats.map((item) => (
      <span>
        <strong>{item.number}</strong>
        <em>{item.label[lang]}</em>
      </span>
    ))}
  </section>

  <BuyerSegments lang={lang} />

  <SupplyStory lang={lang} />

  <section class="editorial-band">
    <div>
      <p class="eyebrow">وعدنا</p>
      <h2>{company.slogan['ar']}</h2>
      <p class="section-lead">
        تستورد الكسرة الفئات الغذائية الهندية الأساسية وتوردها مباشرةً لمتاجر التجزئة والمطاعم والموزعين والأسر في الإمارات — بجودة ثابتة وخدمة سريعة الاستجابة من رأس الخيمة.
      </p>
    </div>
    <img src={withBase('/images/products-spread.jpg')} alt="حبوب وبقوليات وتوابل هندية مرتبة للاستفسار التجاري" loading="lazy" width="900" height="700" />
  </section>
</BaseLayout>
