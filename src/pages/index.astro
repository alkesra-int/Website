---
import BaseLayout from '@/layouts/BaseLayout.astro';
import BuyerSegments from '@/components/BuyerSegments.astro';
import HomeHero from '@/components/HomeHero.astro';
import SupplyStory from '@/components/SupplyStory.astro';
import { company, pages } from '@/data/content';
import { withBase } from '@/utils/paths';

const lang = 'en';
const page = pages.home;
---

<BaseLayout lang={lang} pageKey="home" title={page.meta[lang].title} description={page.meta[lang].description}>
  <HomeHero lang={lang} />

  <section class="trust-strip" aria-label="Al Kesra highlights">
    {page.stats.map((item) => <span>{item[lang]}</span>)}
  </section>

  <BuyerSegments lang={lang} />

  <SupplyStory lang={lang} />

  <section class="editorial-band">
    <div>
      <p class="eyebrow">Our promise</p>
      <h2>{company.slogan['en']}</h2>
      <p>
        Al Kesra sources Indian staple categories and supplies them directly to UAE retailers, restaurants, wholesalers, and households — with consistent quality and responsive service from Ras Al Khaimah.
      </p>
    </div>
    <img src={withBase('/images/products-spread.jpg')} alt="Indian grains, pulses, and spices arranged for trade inquiry" loading="lazy" width="900" height="700" />
  </section>
</BaseLayout>
