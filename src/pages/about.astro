---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/PageHero.astro';
import SectionHeader from '@/components/SectionHeader.astro';
import { pages } from '@/data/content';

const lang = 'en';
const page = pages.about;
---

<BaseLayout lang={lang} pageKey="about" title={page.meta[lang].title} description={page.meta[lang].description}>
  <PageHero
    lang={lang}
    eyebrow={page.hero.eyebrow[lang]}
    title={page.hero.title[lang]}
    lead={page.hero.lead[lang]}
    image={page.hero.image}
    imageAlt="Foodstuff trading ingredients and pantry staples"
  />

  <section class="content-band">
    <SectionHeader
      eyebrow="Who we are"
      title="A Ras Al Khaimah foodstuff company with an Indian staples focus"
      copy="Al Kesra connects Indian agro-food categories with UAE buyers through practical import, export, trading, and sourcing coordination."
    />
    <div class="values-grid">
      {page.values.map((value) => (
        <article class="value-tile">
          <h3>{value.title[lang]}</h3>
          <p>{value.copy[lang]}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="split-section split-section--dark">
    <div>
      <p class="eyebrow">Vision</p>
      <h2>To build a trusted UAE-based bridge that brings India's everyday food essentials to global tables with quality, consistency, and long-term partnership.</h2>
    </div>
    <p>
      Our mission is to source and supply rice, grains, pulses, spices, oils, sugar, flour, packaged goods, and related foodstuff categories through ethical sourcing, clear communication, competitive coordination, and dependable follow-up for retailers, restaurants, wholesalers, and households.
    </p>
  </section>
</BaseLayout>
