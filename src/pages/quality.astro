---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/PageHero.astro';
import QualityNotes from '@/components/QualityNotes.astro';
import SectionHeader from '@/components/SectionHeader.astro';
import { pages } from '@/data/content';
import { withBase } from '@/utils/paths';

const lang = 'en';
const page = pages.quality;
---

<BaseLayout lang={lang} pageKey="quality" title={page.meta[lang].title} description={page.meta[lang].description}>
  <PageHero
    lang={lang}
    eyebrow={page.hero.eyebrow[lang]}
    title={page.hero.title[lang]}
    lead={page.hero.lead[lang]}
    image={page.hero.image}
    imageAlt="Packaged pantry goods and dry food ingredients"
  />

  <section class="content-band">
    <SectionHeader
      eyebrow="How we work"
      title="Straightforward sourcing, no shortcuts"
      copy="Al Kesra handles each order directly — confirming product specifications, pack options, quantities, and delivery requirements before committing to supply."
    />
    <div class="values-grid">
      {page.pillars.map((pillar) => (
        <article class="value-tile">
          <h3>{pillar.title[lang]}</h3>
          <p>{pillar.copy[lang]}</p>
        </article>
      ))}
    </div>
  </section>

  <QualityNotes lang={lang} />

  <section class="process-ribbon" style={`--process-image: url('${withBase('/images/quality-packaging.jpg')}')`}>
    <div>
      <p class="eyebrow">Sourcing flow</p>
      <h2>From first inquiry to confirmed order, handled directly by our team</h2>
    </div>
    <p>
      Al Kesra handles inquiries directly — from category selection through pack and quantity details, coordinated through a responsive UAE-based team.
    </p>
  </section>
</BaseLayout>
