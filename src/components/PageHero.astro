---
import { common, routes, type Lang } from '@/data/content';
import { withBase } from '@/utils/paths';

interface HeroCta {
  label: string;
  href: string;
}

interface Props {
  lang: Lang;
  eyebrow: string;
  title: string;
  lead: string;
  image: string;
  imageAlt: string;
  primaryCta?: HeroCta;
  secondaryCta?: HeroCta;
}

const { lang, eyebrow, title, lead, image, imageAlt, primaryCta, secondaryCta } = Astro.props;
const defaultPrimaryCta = {
  label: common.ctas.products[lang],
  href: withBase(`${routes.products[lang]}#product-inquiry`)
};
const defaultSecondaryCta = {
  label: common.ctas.contact[lang],
  href: withBase(routes.contact[lang])
};
const primary = primaryCta ?? defaultPrimaryCta;
const secondary = secondaryCta ?? defaultSecondaryCta;
---

<section class="page-hero" style={`--hero-image: url('${withBase(image)}')`} aria-label={imageAlt}>
  <div class="page-hero__image" data-parallax-bg></div>
  <div class="page-hero__texture" aria-hidden="true"></div>
  <div class="page-hero__inner" data-parallax-content>
    <div class="page-hero__copy">
      <p class="eyebrow">{eyebrow}</p>
      <h1>{title}</h1>
      <p class="hero-lead">{lead}</p>
      <div class="hero-actions">
        <a class="button button-primary" href={primary.href}>{primary.label}</a>
        <a class="button button-secondary" href={secondary.href}>{secondary.label}</a>
      </div>
    </div>
    <div class="hero-panel reveal-card">
      <span>{lang === 'en' ? 'Sourcing route' : 'مسار التوريد'}</span>
      <strong>{lang === 'en' ? 'India' : 'الهند'}</strong>
      <i></i>
      <strong>{lang === 'en' ? 'UAE' : 'الإمارات'}</strong>
      <small>{lang === 'en' ? 'Category-led foodstuff inquiries' : 'استفسارات غذائية حسب الفئات'}</small>
    </div>
  </div>
</section>
