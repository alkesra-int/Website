---
import { company, navItems, routes, type Lang } from '@/data/content';
import { withBase } from '@/utils/paths';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <img src={withBase('/images/al-kesra-logo.png')} alt={lang === 'en' ? 'Al Kesra International LLC logo' : 'شعار شركة الكسرة الدولية'} width="120" height="74" />
      <p>{company.slogan[lang]}</p>
    </div>

    <nav class="footer-links" aria-label={lang === 'en' ? 'Footer navigation' : 'تنقل التذييل'}>
      {navItems.map((item) => (
        <a href={withBase(routes[item.key][lang])}>{item.label[lang]}</a>
      ))}
    </nav>

    <address class="footer-contact">
      <span>{lang === 'en' ? company.name : 'شركة الكسرة الدولية ذ.م.م'}</span>
      <span>{company.location[lang]}</span>
      <a href={`mailto:${company.email}`}>{company.email}</a>
    </address>
  </div>
  <div class="footer-bottom">
    <span>© {new Date().getFullYear()} {lang === 'en' ? company.name : company.arabicName}</span>
    <span>{lang === 'en' ? company.slogan.en : company.slogan.ar}</span>
  </div>
</footer>
