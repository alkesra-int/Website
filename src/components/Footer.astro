---
import Icon from '@/components/Icon.astro';
import { categories, company, navItems, routes, type Lang } from '@/data/content';
import { withBase } from '@/utils/paths';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <a href={withBase(routes.home[lang])} aria-label={company.name} class="footer-brand-mark">
        <span class="footer-brand-icon" aria-hidden="true">
          <img src={withBase('/images/al-kesra-logo-mark.svg')} alt="" width="28" height="42" />
        </span>
        <span class="footer-brand-name">
          <strong>{lang === 'en' ? 'Al Kesra' : company.arabicName}</strong>
          <small>{lang === 'en' ? 'International LLC' : 'الدولية ذ.م.م'}</small>
        </span>
      </a>
      <p class="eyebrow">{lang === 'en' ? 'UAE based foodstuff trading' : 'تجارة مواد غذائية من الإمارات'}</p>
      <h2>{company.slogan[lang]}</h2>
      <p>{lang === 'en' ? 'Indian foodstuff trading from Ras Al Khaimah - rice, grains, flour, pulses, spices, sugar, oils, packaged goods, fresh produce, and support categories for UAE buyers.' : 'تجارة مواد غذائية هندية من رأس الخيمة - أرز وحبوب ودقيق وبقوليات وتوابل وسكر وزيوت ومواد معبأة ومنتجات طازجة وفئات داعمة للمشترين في الإمارات.'}</p>
    </div>

    <nav class="footer-links" aria-label={lang === 'en' ? 'Footer navigation' : 'تنقل التذييل'}>
      <strong>{lang === 'en' ? 'Explore' : 'تصفح'}</strong>
      {navItems.map((item) => (
        <a href={withBase(routes[item.key][lang])}>{item.label[lang]}</a>
      ))}
    </nav>

    <div class="footer-categories" aria-label={lang === 'en' ? 'Product categories' : 'فئات المنتجات'}>
      <strong>{lang === 'en' ? 'Our categories' : 'فئاتنا'}</strong>
      <div>
        {categories.map((category) => (
          <span style={`--category-accent: ${category.accent}`}>
            <Icon name={category.icon} />
            {category.short[lang]}
          </span>
        ))}
      </div>
    </div>

    <address class="footer-contact">
      <strong>{lang === 'en' ? 'Contact' : 'تواصل'}</strong>
      <span>{lang === 'en' ? company.name : 'شركة الكسرة الدولية ذ.م.م'}</span>
      <span>{company.location[lang]}</span>
      <a href={`mailto:${company.email}`}>{company.email}</a>
      <a href={`https://wa.me/${company.whatsapp.replace(/\D/g, '')}`}>{lang === 'en' ? 'WhatsApp:' : 'واتساب:'} {company.whatsapp}</a>
      <a href={`tel:${company.phone.replace(/\s/g, '')}`}>{lang === 'en' ? 'Phone:' : 'هاتف:'} {company.phone}</a>
    </address>
  </div>
  <div class="footer-bottom">
    <span>© {new Date().getFullYear()} {lang === 'en' ? company.name : company.arabicName}</span>
  </div>
</footer>
