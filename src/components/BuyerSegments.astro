---
import Icon from '@/components/Icon.astro';
import { buyerSegments, type Lang } from '@/data/content';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<section class="buyer-section">
  <div class="section-header">
    <p class="eyebrow">{lang === 'en' ? 'Who we supply' : 'من نورده'}</p>
    <h2>{lang === 'en' ? 'Supplying retailers, restaurants, wholesalers, and homes across the UAE' : 'نورد لمتاجر التجزئة والمطاعم والموزعين والأسر في الإمارات'}</h2>
    <p>
      {lang === 'en'
        ? 'Al Kesra supplies Indian foodstuff to retail chains, restaurants, caterers, wholesalers, and household buyers across the UAE — with consistent availability and competitive pricing.'
        : 'تورد الكسرة المواد الغذائية الهندية لسلاسل التجزئة والمطاعم وشركات الضيافة والموزعين والمشترين الأسريين في الإمارات — بتوفر ثابت وأسعار تنافسية.'}
    </p>
  </div>
  <div class="buyer-grid">
    {buyerSegments.map((segment) => (
      <article class="buyer-card reveal-card">
        <div class="icon-box"><Icon name={segment.icon} /></div>
        <h3>{segment.title[lang]}</h3>
        <p>{segment.copy[lang]}</p>
      </article>
    ))}
  </div>
</section>
