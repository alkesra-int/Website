---
import { common, company, type Lang } from '@/data/content';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<aside class="quote-basket" aria-live="polite" data-quote-basket data-whatsapp={company.whatsapp.replace(/\D/g, '')}>
  <button class="quote-basket__toggle" type="button" data-quote-toggle aria-expanded="false">
    <span>{common.quote.title[lang]}</span>
    <strong data-quote-count>0</strong>
  </button>
  <div class="quote-basket__panel" data-quote-panel hidden>
    <div class="quote-basket__header">
      <div class="quote-basket__header-text">
        <h2>{common.quote.title[lang]}</h2>
        <p>{lang === 'en' ? 'Select categories for pricing follow-up' : 'اختر الفئات لمتابعة الأسعار'}</p>
      </div>
      <button type="button" data-quote-close aria-label={lang === 'en' ? 'Close inquiry basket' : 'إغلاق سلة الاستفسار'}>×</button>
    </div>
    <div class="quote-basket__body">
      <p class="quote-basket__empty" data-quote-empty>{common.quote.empty[lang]}</p>
      <ul class="quote-basket__items" data-quote-items></ul>
      <label class="quote-basket__field">
        <span>{lang === 'en' ? 'Inquiry note' : 'ملاحظة الاستفسار'}</span>
        <textarea data-quote-note rows="3" placeholder={lang === 'en' ? 'Quantity, pack size, destination...' : 'الكمية، حجم العبوة، الوجهة...'}></textarea>
      </label>
    </div>
    <div class="quote-basket__actions">
      <a class="button button-primary quote-basket__send is-disabled" href="#" data-quote-send aria-disabled="true">{common.quote.send[lang]}</a>
      <div class="quote-basket__secondary">
        <button class="button button-ghost" type="button" data-quote-clear>{common.quote.clear[lang]}</button>
        <button class="button button-ghost" type="button" data-quote-copy>{lang === 'en' ? 'Copy inquiry' : 'نسخ الاستفسار'}</button>
      </div>
    </div>
    <p class="quote-basket__feedback" data-quote-feedback hidden></p>
  </div>
</aside>
