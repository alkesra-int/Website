---
import Icon from '@/components/Icon.astro';
import { routeSteps } from '@/data/content';
import type { Lang } from '@/data/content';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

---

<section class="supply-story" data-route-story>
  <div class="section-header">
    <p class="eyebrow">{lang === 'en' ? 'Supply story' : 'قصة التوريد'}</p>
    <h2>{lang === 'en' ? 'From Indian farms to UAE shelves and kitchens' : 'من مزارع الهند إلى رفوف الإمارات ومطابخها'}</h2>
    <p>
      {lang === 'en'
        ? 'Al Kesra sources Indian staples directly and coordinates supply to UAE retail, food service, and wholesale buyers from our Ras Al Khaimah base.'
        : 'تستورد الكسرة السلع الأساسية الهندية مباشرةً، وتنسّق التوريد لمشتري التجزئة والمطاعم والجملة في الإمارات من قاعدتنا في رأس الخيمة.'}
    </p>
  </div>
  <ol class="story-steps" aria-label={lang === 'en' ? 'Supply route steps' : 'خطوات مسار التوريد'}>
    {routeSteps.map((step, index) => (
      <li data-route-step class:list={[index === 0 && 'is-active']}>
        <span>{String(index + 1).padStart(2, '0')}</span>
        <div class="story-step-icon"><Icon name={step.icon} /></div>
        <strong>{step.title[lang]}</strong>
        <em>{step.label[lang]}</em>
        <p>{step.copy[lang]}</p>
      </li>
    ))}
  </ol>
</section>
