---
import Icon from '@/components/Icon.astro';
import { qualityNotes, type Lang } from '@/data/content';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<section class="quality-notes">
  <div class="section-header">
    <p class="eyebrow">{lang === 'en' ? 'Quality you can rely on' : 'جودة يمكنك الاعتماد عليها'}</p>
    <h2>{lang === 'en' ? 'Reliable sourcing, consistent quality, honest service' : 'مصادر موثوقة وجودة ثابتة وخدمة صادقة'}</h2>
    <p class="section-lead">
      {lang === 'en'
        ? 'Al Kesra provides clear product specifications — variety, grade, pack size, shelf life, and labeling — so buyers can make informed purchasing decisions.'
        : 'توفر الكسرة مواصفات منتج واضحة — الصنف والدرجة وحجم العبوة والعمر الافتراضي والملصقات — لمساعدة المشترين على اتخاذ قرارات شراء مدروسة.'}
    </p>
  </div>
  <div class="quality-note-grid">
    {qualityNotes.map((note) => (
      <article class="quality-note reveal-card">
        <Icon name={note.icon} />
        <h3>{note.title[lang]}</h3>
        <p>{note.copy[lang]}</p>
      </article>
    ))}
  </div>
</section>
