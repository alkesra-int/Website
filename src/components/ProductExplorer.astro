---
import Icon from '@/components/Icon.astro';
import { categories, common, segmentFilters, type Lang } from '@/data/content';
import { withBase } from '@/utils/paths';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<section class="product-explorer" id="product-inquiry" data-product-explorer>
  <div class="product-explorer__intro">
    <div>
      <p class="eyebrow">{lang === 'en' ? 'Our products' : 'منتجاتنا'}</p>
      <h2>{lang === 'en' ? 'Six Indian foodstuff categories, ready to supply' : 'ست فئات من المواد الغذائية الهندية، جاهزة للتوريد'}</h2>
      <p class="section-lead">
        {lang === 'en'
          ? 'Browse by buyer type, review each category, and add what you need to your inquiry basket. Al Kesra will follow up with pricing, pack options, and availability.'
          : 'تصفح حسب نوع المشتري، وراجع كل فئة، وأضف ما تحتاجه إلى سلة الاستفسار. سيتابع معك فريق الكسرة في الأسعار وخيارات التعبئة والتوفر.'}
      </p>
    </div>
    <div class="explorer-meter" aria-hidden="true">
      <Icon name="route" />
      <span>{lang === 'en' ? 'India staples' : 'سلع هندية أساسية'}</span>
      <i>{lang === 'en' ? 'Ras Al Khaimah based' : 'من رأس الخيمة'}</i>
    </div>
  </div>

  <div class="explorer-tabs" role="tablist" aria-label={lang === 'en' ? 'Buyer filters' : 'مرشحات المشتري'}>
    {segmentFilters.map((filter, index) => (
      <button type="button" class:list={[index === 0 && 'is-active']} data-filter={filter.id} role="tab" aria-selected={index === 0 ? 'true' : 'false'}>
        {filter.label[lang]}
      </button>
    ))}
  </div>

  <div class="explorer-grid">
    {categories.map((category) => (
      <article
        class="explorer-card reveal-card"
        style={`--category-accent: ${category.accent}`}
        data-segments={category.segments.join(',')}
        data-category-card
      >
        <div class="explorer-card__image">
          <img src={withBase(category.image)} alt={category.title[lang]} loading="lazy" width="900" height="680" />
          <span class="explorer-card__icon"><Icon name={category.icon} /></span>
        </div>
        <div class="explorer-card__content">
          <div class="explorer-card__topline">
            <span>{category.short[lang]}</span>
            <Icon name="quote" />
          </div>
          <h3>{category.title[lang]}</h3>
          <p>{category.heroLine[lang]}</p>
          <div class="bubble-row" aria-label={lang === 'en' ? 'Category notes' : 'ملاحظات الفئة'}>
            {category.bubbles.slice(0, 3).map((bubble) => (
              <span>
                <Icon name={bubble.icon} />
                {bubble.label[lang]}
              </span>
            ))}
          </div>
          <div class="explorer-card__actions">
            <button
              class="category-add"
              type="button"
              data-quote-add
              data-id={category.id}
              data-title-en={category.title.en}
              data-title-ar={category.title.ar}
            >
              {common.quote.add[lang]}
            </button>
            <button
              class="button button-ghost"
              type="button"
              data-category-open={category.id}
              aria-controls={`category-modal-${category.id}`}
            >
              {lang === 'en' ? 'View details' : 'عرض التفاصيل'}
            </button>
          </div>
        </div>
      </article>
    ))}
  </div>

  {categories.map((category) => (
    <div
      class="category-modal"
      id={`category-modal-${category.id}`}
      role="dialog"
      aria-modal="true"
      aria-labelledby={`category-modal-title-${category.id}`}
      data-category-modal={category.id}
      hidden
    >
      <button class="category-modal__backdrop" type="button" data-category-close aria-label={lang === 'en' ? 'Close category details' : 'إغلاق تفاصيل الفئة'}></button>
      <div class="category-modal__panel" tabindex="-1" style={`--category-accent: ${category.accent}`}>
        <button class="category-modal__close" type="button" data-category-close aria-label={lang === 'en' ? 'Close category details' : 'إغلاق تفاصيل الفئة'}>×</button>
        <div class="category-modal__media">
          <img src={withBase(category.image)} alt={category.title[lang]} loading="lazy" width="1040" height="760" />
        </div>
        <div class="category-modal__body">
          <p class="eyebrow">{lang === 'en' ? 'Category details' : 'تفاصيل الفئة'}</p>
          <h2 id={`category-modal-title-${category.id}`}>{category.title[lang]}</h2>
          <p>{category.modalSummary[lang]}</p>
          <div class="modal-bubbles">
            {category.bubbles.map((bubble) => (
              <span>
                <Icon name={bubble.icon} />
                {bubble.label[lang]}
              </span>
            ))}
          </div>
          <div class="modal-actions">
            <button
              class="category-add"
              type="button"
              data-quote-add
              data-id={category.id}
              data-title-en={category.title.en}
              data-title-ar={category.title.ar}
            >
              {common.quote.add[lang]}
            </button>
            <button class="button button-ghost" type="button" data-category-close>
              {lang === 'en' ? 'Continue browsing' : 'متابعة التصفح'}
            </button>
          </div>
        </div>
      </div>
    </div>
  ))}
</section>
