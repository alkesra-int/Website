---
import Icon from '@/components/Icon.astro';
import { categories, common, segmentFilters, type Lang } from '@/data/content';
import { withBase } from '@/utils/paths';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<section class="product-explorer" data-product-explorer>
  <div class="product-explorer__intro">
    <div>
      <p class="eyebrow">{lang === 'en' ? 'Interactive product finder' : 'مستكشف الفئات التفاعلي'}</p>
      <h2>{lang === 'en' ? 'Start with the buyer, then choose the staple categories' : 'ابدأ بنوع المشتري ثم اختر الفئات الأساسية'}</h2>
      <p>
        {lang === 'en'
          ? 'Use the categories as a starting point, not a fixed catalogue. Share product type, expected quantity, preferred pack size, and buyer segment to guide the next sourcing discussion.'
          : 'استخدم الفئات كنقطة بداية وليست كتالوجاً نهائياً. شارك نوع المنتج والكمية المتوقعة وحجم العبوة المفضل وفئة المشتري لتسهيل نقاش التوريد التالي.'}
      </p>
    </div>
    <div class="explorer-meter" aria-hidden="true">
      <Icon name="route" />
      <span>{lang === 'en' ? 'Category-led inquiry' : 'استفسار حسب الفئة'}</span>
    </div>
  </div>

  <div class="explorer-tabs" role="tablist" aria-label={lang === 'en' ? 'Buyer filters' : 'مرشحات المشتري'}>
    {segmentFilters.map((filter, index) => (
      <button type="button" class:list={[index === 0 && 'is-active']} data-filter={filter.id} role="tab" aria-selected={index === 0 ? 'true' : 'false'}>
        {filter.label[lang]}
      </button>
    ))}
  </div>

  <div class="explorer-grid">
    {categories.map((category) => (
      <article class="explorer-card reveal-card" style={`--category-accent: ${category.accent}`} data-segments={category.segments.join(',')}>
        <div class="explorer-card__image">
          <img src={withBase(category.image)} alt={category.title[lang]} loading="lazy" width="900" height="680" />
        </div>
        <div class="explorer-card__content">
          <div class="explorer-card__topline">
            <span>{category.short[lang]}</span>
            <Icon name="quote" />
          </div>
          <h3>{category.title[lang]}</h3>
          <p>{category.detail[lang]}</p>
          <dl>
            <div>
              <dt>{lang === 'en' ? 'Best for' : 'مناسبة لـ'}</dt>
              <dd>{category.bestFor[lang]}</dd>
            </div>
          </dl>
          <button
            class="category-add"
            type="button"
            data-quote-add
            data-id={category.id}
            data-title-en={category.title.en}
            data-title-ar={category.title.ar}
          >
            {common.quote.add[lang]}
          </button>
        </div>
      </article>
    ))}
  </div>
</section>
